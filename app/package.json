{
  "name": "@maparescate/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && cp staticwebapp.config.json dist/staticwebapp.config.json",
    "lint": "tsc -b --noEmit",
    "e2e:mocked": "playwright test",
    "test": "rm -rf .tmp-tests && tsc src/lib/outbox.ts --target ES2020 --module ES2020 --moduleResolution Node --outDir .tmp-tests --skipLibCheck && node --test tests/*.test.mjs; status=$?; rm -rf .tmp-tests; exit $status",
    "preview": "vite preview"
  },
  "dependencies": {
    "azure-maps-control": "^3.5.0",
    "lucide-react": "^1.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/babel__generator": "^7.6.8",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.20.6",
    "@types/estree": "^1.0.9",
    "@types/prop-types": "^15.7.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.5.4",
    "vite": "^6.4.3"
  }
}
